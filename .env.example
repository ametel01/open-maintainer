NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
API_BASE_URL=http://api:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
DATABASE_URL=postgres://open_maintainer:open_maintainer@postgres:5432/open_maintainer
REDIS_URL=redis://redis:6379
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=
ENCRYPTION_KEY=change-me-32-byte-local-dev-key
# Fail API startup when required auth readiness checks fail.
OPEN_MAINTAINER_STRICT_STARTUP_AUTH=false
# Required model CLI auth checks for /auth/ready: codex, claude, codex,claude, or none.
OPEN_MAINTAINER_REQUIRED_MODEL_CLI_AUTH=codex
OPENAI_COMPATIBLE_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_COMPATIBLE_MODEL=llama3.1
